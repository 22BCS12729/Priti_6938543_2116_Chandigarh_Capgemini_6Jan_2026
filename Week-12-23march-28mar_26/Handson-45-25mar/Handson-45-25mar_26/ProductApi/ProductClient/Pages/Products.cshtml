@page
@model ProductsModel

<h2>Products List</h2>

<table border="1">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Price</th>
    </tr>

@foreach (var item in Model.Products)
{
    <tr>
        <td>@item.Id</td>
        <td>@item.Name</td>
        <td>@item.Price</td>
    </tr>
}
</table>