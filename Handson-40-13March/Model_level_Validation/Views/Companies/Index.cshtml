@model IEnumerable<Model_level_Validation.Models.Company>

<h2>Companies Dashboard</h2>

<a asp-action="Create" class="btn btn-success mb-3">
    Add Company
</a>

<table class="table table-bordered">

    <thead class="table-dark">
        <tr>
            <th>Company Name</th>
            <th>Employees</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var company in Model)
        {
            <tr>

                <td>@company.Name</td>

                <td>

                    @if (company.Employees != null && company.Employees.Any())
                    {
                        <ul>
                            @foreach (var emp in company.Employees)
                            {
                                <li>@emp.Name</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <span>No Employees</span>
                    }

                </td>

                <td>

                    <a asp-action="Delete"
                           asp-route-id="@company.Id"
                           class="btn btn-danger">

                        Delete

                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>