<h2 style="text-align:center; color:#2c3e50; font-family:Arial;">🎓 Student Details</h2>

<div style="
    width:350px;
    margin:auto;
    padding:20px;
    border-radius:10px;
    background-color:#f4f6f7;
    box-shadow:0px 4px 10px rgba(0,0,0,0.2);
    font-family:Arial;
">

    <p style="font-size:18px; border-bottom:1px solid #ddd; padding:8px;">
        <strong>ID : 1 </strong> @ViewBag.Id
    </p>

    <p style="font-size:18px; border-bottom:1px solid #ddd; padding:8px;">
        <strong>Name : Priti Mehta </strong> @ViewBag.Name
    </p>

    <p style="font-size:18px; padding:8px;">
        <strong>Age :  21 </strong> @ViewBag.Age
    </p>

</div>