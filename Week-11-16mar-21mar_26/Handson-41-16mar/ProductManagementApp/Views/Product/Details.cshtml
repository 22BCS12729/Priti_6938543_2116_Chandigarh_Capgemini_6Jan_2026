@model ProductManagementApp.Models.Product

<div class="container mt-4">

    <h3>Product Details</h3>

    <div class="card p-4 shadow">

        <p><b>ID:</b> @Model.Id</p>
        <p><b>Name:</b> @Model.Name</p>
        <p><b>Price:</b> ₹ @Model.Price</p>

        <a asp-action="Index" class="btn btn-primary">
            Back
        </a>

    </div>

</div>