<div class="container mt-5">

    <div class="card shadow-lg border-0 text-center p-5">

        <h2 class="mb-3">

            Welcome, @ViewBag.User 👋

        </h2>

        <p class="text-muted">

            You are logged in to the company portal.

        </p>

        <div class="row mt-4">

            <div class="col-md-4">

                <div class="card shadow-sm p-3">

                    <h5>📊 Reports</h5>

                    <p>View company reports</p>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card shadow-sm p-3">

                    <h5>👨‍💼 Employees</h5>

                    <p>Manage employee data</p>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card shadow-sm p-3">

                    <h5>⚙ Settings</h5>

                    <p>Account settings</p>

                </div>

            </div>

        </div>

        <a asp-action="Logout"
               class="btn btn-danger mt-4">

            Logout

        </a>

    </div>

</div>