@model StudentManagementSystem.Models.Student

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        background: linear-gradient(135deg, #667eea, #764ba2);
    }

    .card {
        border-radius: 15px;
    }
</style>

<div class="container mt-5">
    <div class="card shadow-lg p-4 col-md-5 mx-auto">
        <h3 class="text-center mb-4">Student Registration</h3>

        <form method="post">

            <input asp-for="Name" class="form-control mb-3" placeholder="Enter Name" />
            <span asp-validation-for="Name" class="text-danger"></span>

            <input asp-for="Age" class="form-control mb-3" placeholder="Enter Age" />
            <span asp-validation-for="Age" class="text-danger"></span>

            <input asp-for="Email" class="form-control mb-3" placeholder="Enter Email" />
            <span asp-validation-for="Email" class="text-danger"></span>

            <button class="btn btn-primary w-100">Register</button>

            <p class="text-success text-center mt-2">@TempData["msg"]</p>

        </form>
    </div>
</div>