@model ECommerceApp.Models.Customer

<h2 class="mb-4 fw-bold">👤 Add Customer</h2>

<div class="card shadow p-4">

    <form asp-action="Create" method="post">

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label class="form-label fw-bold">Name</label>
            <input asp-for="Name" class="form-control" placeholder="Enter name" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Email</label>
            <input asp-for="Email" class="form-control" placeholder="Enter email" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Phone</label>
            <input asp-for="Phone" class="form-control" placeholder="Enter phone" />
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-warning px-4">Save</button>
            <a href="/Customer" class="btn btn-secondary px-4">Back</a>
        </div>

    </form>

</div>