@model IEnumerable<ECommerceApp.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<h2 class="mb-4 fw-bold">🛒 Product Management</h2>

<!-- 🔥 ACTION BUTTONS -->
<div class="mb-3 d-flex gap-2">
    <a href="/Product/Create" class="btn btn-primary">➕ Add Product</a>
    <a href="/Category/Create" class="btn btn-success">➕ Add Category</a>
</div>

<!-- 🔥 CATEGORY FILTER -->
<form method="get" class="mb-3">
    <select name="categoryId" class="form-select w-25" onchange="this.form.submit()">
        <option value="">All Categories</option>
        @foreach (var cat in ViewBag.Categories)
        {
            <option value="@cat.Id">@cat.Name</option>
        }
    </select>
</form>

<!-- 🔥 PRODUCT TABLE -->
<div class="card shadow">
    <div class="card-header bg-dark text-white">
        Product List
    </div>

    <div class="card-body">

        <table class="table table-hover table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Price</th>
                    <th>Category</th>
                    <th style="width:200px;">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>₹ @item.Price</td>
                        <td>@item.Category?.Name</td>

                        <td>
                            <a href="/Product/Edit/@item.Id" class="btn btn-warning btn-sm">Edit</a>
                            <a href="/Product/Delete/@item.Id" class="btn btn-danger btn-sm">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>