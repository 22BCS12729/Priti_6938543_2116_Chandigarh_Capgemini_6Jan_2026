@model ECommerceApp.Models.Product

<h2>Edit Product</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />

    <input asp-for="Name" class="form-control mb-2" />
    <input asp-for="Price" class="form-control mb-2" />

    <select asp-for="CategoryId" class="form-control mb-2"
            asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
    </select>

    <button class="btn btn-warning">Update</button>
</form>