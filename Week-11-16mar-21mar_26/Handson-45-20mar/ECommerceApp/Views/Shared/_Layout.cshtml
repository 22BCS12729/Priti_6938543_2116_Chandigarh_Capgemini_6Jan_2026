<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ECommerceApp</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

    <div class="d-flex">

        <!-- 🔥 SIDEBAR -->
        <div class="bg-dark text-white p-3 vh-100 shadow" style="width:250px;">
            <h4 class="text-center mb-4">🛒 Admin Panel</h4>

            <ul class="nav flex-column">

                <li class="nav-item mb-2">
                    <a class="nav-link text-white" href="/Admin/Dashboard">📊 Dashboard</a>
                </li>

                <li class="nav-item mb-2">
                    <a class="nav-link text-white" href="/Product">🛍 Products</a>
                </li>

                <li class="nav-item mb-2">
                    <a class="nav-link text-white" href="/Category">📂 Categories</a>
                </li>

                <li class="nav-item mb-2">
                    <a class="nav-link text-white" href="/Customer">👤 Customers</a>
                </li>

                <li class="nav-item mb-2">
                    <a class="nav-link text-white" href="/Order">📦 Orders</a>
                </li>

            </ul>
        </div>

        <!-- 🔥 MAIN CONTENT -->
        <div class="flex-grow-1">

            <!-- TOP NAVBAR -->
            <nav class="navbar navbar-light bg-light shadow-sm px-3">
                <span class="navbar-brand mb-0 h5">E-Commerce Management</span>
            </nav>

            <!-- PAGE CONTENT -->
            <div class="container mt-4">
                @RenderBody()
            </div>

        </div>

    </div>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>