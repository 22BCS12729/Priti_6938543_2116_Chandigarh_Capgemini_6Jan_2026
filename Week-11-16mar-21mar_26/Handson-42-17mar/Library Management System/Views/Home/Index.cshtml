@{
    ViewData["Title"] = "Home";
}

<div class="container text-center mt-5">

    <!-- HERO SECTION -->
    <div class="p-5 mb-4 bg-dark text-white rounded-4 shadow-lg">
        <h1 class="display-4 fw-bold">📚 Library Management System</h1>
        <p class="lead mt-3">
            Manage books, track availability, and build your digital library easily.
        </p>

        <a href="/Books" class="btn btn-success btn-lg mt-3 px-4">
            📖 View Books
        </a>

        <a href="/Books/Create" class="btn btn-outline-light btn-lg mt-3 px-4">
            ➕ Add Book
        </a>
    </div>

    <!-- FEATURES SECTION -->
    <div class="row mt-4">

        <div class="col-md-4">
            <div class="card shadow-lg border-0 rounded-4 p-3">
                <h4>📚 Manage Books</h4>
                <p>Add, view and organize all your books easily.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-lg border-0 rounded-4 p-3">
                <h4>🔍 Easy Access</h4>
                <p>Quickly browse and check book availability.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-lg border-0 rounded-4 p-3">
                <h4>⚡ Fast System</h4>
                <p>Simple and efficient library management system.</p>
            </div>
        </div>

    </div>

</div>