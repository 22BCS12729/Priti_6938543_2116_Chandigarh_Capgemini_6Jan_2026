@model JwtMvcDemo.Models.User

<div class="container mt-5">
    <div class="card p-4 shadow">
        <h3 class="text-center">Create Account</h3>

        <form asp-action="Register" method="post">
            <input asp-for="Username" class="form-control mb-3" placeholder="Enter Username" />
            <input asp-for="Password" type="password" class="form-control mb-3" placeholder="Enter Password" />

            <button class="btn btn-success w-100">Create Account</button>
        </form>

        <a asp-action="Login" class="d-block text-center mt-3">
            Already have account? Login
        </a>
    </div>
</div>