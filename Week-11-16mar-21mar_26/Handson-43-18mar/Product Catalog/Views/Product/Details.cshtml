@model StudentApp.Models.Product

<div class="container mt-4">

    <div class="card p-4 shadow">

        <img src="@Model.ImageUrl" height="300" class="mb-3" />

        <h2>@Model.Name</h2>
        <h4 class="text-success">₹ @Model.Price</h4>

        <p>@Model.Description</p>

        <a href="/Product" class="btn btn-secondary">Back</a>

    </div>

</div>